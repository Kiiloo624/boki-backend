# Copy this file to .env and fill in your values
# Never commit .env to git

APP_ENV=development
DEBUG=true

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep this secret — full DB access
SUPABASE_ANON_KEY=your-anon-key-here                   # Safe to use in clients

# --- Gemini (AI Agent) ---
# Get from: https://aistudio.google.com → Get API Key
# Same Google account as Maps — one billing setup
GEMINI_API_KEY=AIza...

# --- Google Maps ---
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Geocoding API, Directions API
GOOGLE_MAPS_API_KEY=AIza...

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","https://boki.app"]

# --- SerpApi (Google Maps scraping without a Google Maps key) ---
# Get from: https://serpapi.com → Dashboard → API Key
# Free tier: 250 searches/month
SERPAPI_KEY=your-serpapi-key-here

# --- Groq (Chatbot) ---
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key-here

# --- Admin Routes ---
# Protects /scraper/* endpoints — use a long random string
ADMIN_API_KEY=your-secret-admin-key-here

# --- Rate Limiting ---
AGENT_DAILY_ACTION_LIMIT=10
